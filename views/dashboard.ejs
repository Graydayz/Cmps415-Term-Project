<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>

<div class="nav">
  <div>Message System</div>
  <div>
    <a href="/dashboard">Dashboard</a> |
    <a href="/topics">Topics</a> |
    <a href="/stats/topics">Stats</a> |
    <a href="/login">Logout</a>
  </div>
</div>

<div class="container">

  <h1>Welcome, <%= user.username %></h1>

  <h2>Your Subscribed Topics</h2>

  <% if (topics.length === 0) { %>
    <p>You are not subscribed to any topics yet.</p>
  <% } %>

  <% topics.forEach(topic => { %>
    <div class="card">
      <h3><%= topic.title %></h3>

      <h4>Recent Messages:</h4>
      <% if (topicMessages[topic._id].length === 0) { %>
        <p>No messages yet.</p>
      <% } else { %>
        <% topicMessages[topic._id].forEach(msg => { %>
          <div class="card">
            <strong><%= msg.author.username %>:</strong> 
            <p><%= msg.content %></p>
          </div>
        <% }) %>
      <% } %>

      <form action="/topics/<%= topic._id %>/unsubscribe" method="POST">
        <button type="submit">Unsubscribe</button>
      </form>

      <form action="/topics/<%= topic._id %>/messages" method="POST">
        <input type="text" name="content" placeholder="Write a message..." required>
        <button type="submit">Post</button>
      </form>
    </div>
  <% }) %>

  <a href="/topics">View all topics</a>

</div>
</body>
</html>
